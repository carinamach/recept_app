    {
      "id": "seed-004",
      "title": "Yuzu panna cotta",
      "description": "Quietly luxurious: milk cream set, ribbons of citrus, barely sweet.",
      "category": "dessert",
      "cookTimeMinutes": 20,
      "servings": 6,
      "ingredients": [
        {
          "amount": "480 ml",
          "name": "heavy cream"
        },
        {
          "amount": "120 ml",
          "name": "whole milk"
        },
        {
          "amount": "½ cup",
          "name": "sugar"
        },
        {
          "amount": "2 tsp",
          "name": "gelatin powder"
        },
        {
          "amount": "2 tbsp",
          "name": "cold water"
        },
        {
          "amount": "3 tbsp",
          "name": "yuzu juice"
        },
        {
          "amount": "pinch",
          "name": "fine sea salt"
        }
      ],
      "steps": [
        {
          "text": "Bloom gelatin in water for 5 minutes."
        },
        {
          "text": "Warm cream, milk, sugar, and salt until steamy; off heat, whisk in gelatin."
        },
        {
          "text": "Stir in yuzu juice; strain into ramekins; chill 4 hours."
        },
        {
          "text": "Unmold or serve in glass; garnish with citrus supremes if desired."
        }
      ],
      "imageUrl": "https://images.unsplash.com/photo-1551024506-0bccd828d307?auto=format&fit=crop&w=1600&q=80",
