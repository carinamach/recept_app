      "id": "seed-001",
      "title": "Miso butter morning eggs",
      "description": "Silky custardy eggs whispering umami — the kind of breakfast you plate on ceramics and linger over.",
      "category": "breakfast",
      "cookTimeMinutes": 12,
      "servings": 2,
      "ingredients": [
        {
          "amount": "4",
          "name": "large eggs"
        },
        {
          "amount": "1 tbsp",
          "name": "white miso paste"
        },
        {
          "amount": "1 tbsp",
          "name": "unsalted butter"
        },
        {
          "amount": "2 tsp",
          "name": "soy sauce"
        },
        {
          "amount": "1 tbsp",
          "name": "thinly sliced scallions"
        },
        {
          "amount": "to taste",
          "name": "toasted sesame seeds"
        }
      ],
      "steps": [
        {
          "text": "Whisk miso with a splash of warm water until smooth."
        },
        {
          "text": "Melt butter in a non-stick pan over low heat; swirl in miso and soy sauce."
        },
        {
          "text": "Crack in eggs and cook gently, tilting to set whites while keeping yolks silky."
        },
        {
          "text": "Finish with scallions and sesame seeds. Serve immediately on warm rice."
        }
      ],
