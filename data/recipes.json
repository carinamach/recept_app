      "id": "seed-006",
      "title": "Charred eggplant rice bowl",
      "description": "Smoky-soft eggplant draped over warm rice with quick pickles.",
      "category": "lunch",
      "cookTimeMinutes": 35,
      "servings": 2,
      "ingredients": [
        {
          "amount": "2",
          "name": "medium eggplants"
        },
        {
          "amount": "3 tbsp",
          "name": "miso-tahini glaze"
        },
        {
          "amount": "2 cups",
          "name": "cooked short-grain rice"
        },
        {
          "amount": "½ cup",
          "name": "quick-pickled cucumber"
        },
        {
          "amount": "1",
          "name": "soft-boiled egg"
        },
        {
          "amount": "to taste",
          "name": "shichimi togarashi"
        }
      ],
      "steps": [
        {
          "text": "Broil eggplant until deeply charred and collapsed; scoop flesh."
        },
        {
          "text": "Fold eggplant through warm glaze."
        },
        {
          "text": "Pack rice in bowls; top with eggplant, pickles, halved egg."
        },
        {
          "text": "Finish with togarashi and a drizzle of good-quality oil."
        }
      ],
