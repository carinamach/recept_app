    {
      "id": "seed-002",
      "title": "Shoyu ramen with scallion oil",
      "description": "Clear shoyu broth, springy noodles, and a glossy scallion aroma oil on top.",
      "category": "lunch",
      "cookTimeMinutes": 45,
      "servings": 3,
      "ingredients": [
        {
          "amount": "900 ml",
          "name": "good chicken broth"
        },
        {
          "amount": "3 tbsp",
          "name": "Japanese soy sauce"
        },
        {
          "amount": "1 tbsp",
          "name": "mirin"
        },
        {
          "amount": "3 portions",
          "name": "fresh ramen noodles"
        },
        {
          "amount": "6",
          "name": "ramen eggs (ajitsuke tamago)"
        },
        {
          "amount": "¼ cup",
          "name": "thinly sliced scallions"
        },
        {
          "amount": "3 tbsp",
          "name": "neutral oil, for scallion oil"
        }
      ],
      "steps": [
        {
          "text": "Simmer broth with soy sauce and mirin for 10 minutes; taste for balance."
        },
        {
          "text": "Heat oil until just shimmering, pour over scallions in a heatproof bowl; cool."
        },
        {
          "text": "Cook noodles per package; divide into bowls with hot broth."
        },
        {
          "text": "Top with eggs, scallion oil, and extra scallions."
        }
      ],
      "imageUrl": "https://images.unsplash.com/photo-1569718212165-3a8278d5f624?auto=format&fit=crop&w=1600&q=80",
