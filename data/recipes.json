      "id": "seed-003",
      "title": "Gochugaru-glazed salmon",
      "description": "Honey-glossed heat, crisp edges, and a citrus finish for weeknight glamour.",
      "category": "dinner",
      "cookTimeMinutes": 25,
      "servings": 4,
      "ingredients": [
        {
          "amount": "4",
          "name": "salmon fillets, skin-on"
        },
        {
          "amount": "2 tbsp",
          "name": "gochugaru"
        },
        {
          "amount": "2 tbsp",
          "name": "honey"
        },
        {
          "amount": "2 tbsp",
          "name": "soy sauce"
        },
        {
          "amount": "2 cloves",
          "name": "garlic, grated"
        },
        {
          "amount": "1",
          "name": "lime, zested and juiced"
        },
        {
          "amount": "1 tbsp",
          "name": "toasted sesame oil"
        }
      ],
      "steps": [
        {
          "text": "Whisk glaze ingredients until cohesive."
        },
        {
          "text": "Pat salmon dry; sear skin-side down in an oiled skillet until crispy."
        },
        {
          "text": "Flip briefly, reduce heat, spoon glaze repeatedly until lacquered."
        },
        {
          "text": "Rest 3 minutes; finish with lime zest."
        }
      ],
