      "id": "seed-005",
      "title": "Iced jasmine oolong latte",
      "description": "Floral lift, mellow tea tannin, and milk like silk over ice.",
      "category": "drinks",
      "cookTimeMinutes": 8,
      "servings": 2,
      "ingredients": [
        {
          "amount": "240 ml",
          "name": "strong brewed jasmine tea, chilled"
        },
        {
          "amount": "120 ml",
          "name": "oat milk (or dairy)"
        },
        {
          "amount": "1 tbsp",
          "name": "brown sugar syrup"
        },
        {
          "amount": "ice",
          "name": "large cubes"
        },
        {
          "amount": "optional",
          "name": "thin lemon peel"
        }
      ],
      "steps": [
        {
          "text": "Brew jasmine tea strong; chill completely."
        },
        {
          "text": "Shake chilled tea with syrup until frothy."
        },
        {
          "text": "Fill glasses with ice; pour tea three-quarters; float milk gently."
        },
        {
          "text": "Stir before sipping; garnish with citrus oils if desired."
        }
      ],
